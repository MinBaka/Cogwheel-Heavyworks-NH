	quest.613DEA01C46DBC3D.quest_desc: ["鼠标移上去按b前往百科查看详细教程"]
	quest.616028F3CC32A916.quest_desc: [
		"你可以完全自动化你的所有产线！请思索这些物品，活用工厂仪表、无限红石信号终端进行产线、产物配置。"
		"存量转信器可以实现满仓自动启停。"
		"建造你的超级工厂吧！"
	]
