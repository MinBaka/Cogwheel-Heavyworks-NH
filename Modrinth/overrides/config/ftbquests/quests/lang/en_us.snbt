	]
	quest.26B3A37E0E82D7A8.title: "吸血鬼的武器"
	quest.26F9974F8607D9A4.quest_subtitle: "查阅教程书"
	quest.26FDDAF08AFC0D26.quest_desc: ["强大的末影龙在紫色的光芒中消逝，这个来自终末之地的强大生物被你击败，你发现了一些有趣的东西......"]
	quest.2751513D35B2BD93.quest_desc: [""]
	quest.27739CE655B8887D.quest_desc: ["前往星空之前，你需要做如下准备"]
	quest.27B0C29045F4E427.quest_desc: ["你生啃过好多人类心脏，现在你决定把它切块，这样吃起来更方便了"]
	quest.2833221AE971010C.quest_desc: [
		"可以重命名一个物理结构"
		""
		"/vs rename <insert-slug-here> <insert-new-slug-here>"
		""
		"前一个中括号表示现名字，后一个中括号表示新名字"
		"可以使用get-ship指令获取现名字，或者命令行自动选择与补全"
	]
	quest.285A8FA3A333C2AC.quest_desc: ["螺丝刀用于切换后面三种方块的模式"]
	quest.285BBE3DA2A9A46A.title: "魔花床"
	quest.2870A03B5DBF21F2.quest_desc: [
		"襟翼产生的是更为真实的作用力，与物理结构的运动方向和自身角度有关"
		"不同于机翼，机翼旋转即可提供力，而襟翼提供力靠的是空气的反作用力"
		"因此，如果你想要使用襟翼作为螺旋桨推进，那么襟翼需要倾斜角度，参考现实生活的风扇"
		"但并不推荐这样做，襟翼作为螺旋桨旋转产生的力很不稳定，表现为物理结构抖来抖去"
	]
	quest.2894DA7F4C272AA8.quest_desc: [
		"更好的下届要塞，里面可以找到一些机械动力的机器"
		"（主房间有个3*3的岩浆池，池底有一颗远古残骸）"
		"使用指令或者指南针需要搜：Betterfortress，而不是原版fortress"
	]
	quest.28B5C10016509C6F.quest_desc: [
		"此章节用于展示包内适合的护甲与其梯度。"
		"注意，所有护甲都要搭配附魔使用。"
	]
	quest.28D0CED2F6F083FA.quest_desc: ["至高木森林，可以刷新特有结构、生成魔法生物等。查看教程书获取详细内容"]
	quest.28D0CED2F6F083FA.title: "至高木森林"
	quest.2900FBA731F1E926.title: "冰刃"
	quest.29488F9A62FB28C9.quest_desc: [
		"吸血鬼猎人&e4级以后右边技能点&r才可用。"
		"使用方法：向里面倒一桶岩浆，之后合成即可。"
		"每次合成，都会消耗岩浆，多次后需重新装岩浆。"
	]
	quest.29782AB9649E9D2B.title: "厚土法师套装"
	quest.299BAE1CC79785A1.quest_desc: ["&6你建造了如此多的机械、达成了无数壮举，你的机械技术能力已经达到巅峰！"]
	quest.299BAE1CC79785A1.title: "&6技术实力！"
	quest.29E5FF670234420A.title: "同心"
	quest.2AAE936C50591B10.quest_desc: ["除了让人感染吸血之疾以外，它还可以用来在研究台做研究，获得猎人情报"]
	quest.2AC8971E56673515.title: "金光闪闪"
	quest.2B586D1A20812478.quest_desc: ["一张完美的魔法地图将为你的冒险提供极大的便利"]
	quest.2B586D1A20812478.title: "暮色森林"
	quest.2BAF68FC7BD3801C.quest_desc: [
		"使用后会使 5 * 5 * 5 的&6子区块&r不再生成带有等级的怪物。"
		""
		"玩家难度值提升时给予的奖励是获取它的唯一方式，可以用于制作混沌锭和恶意净化药水。"
	]
	quest.2C52BF5F9A329E5D.quest_desc: ["法术过滤魔符"]
	quest.2CD5686B2C07A8DB.quest_desc: [
		"&d魔法不止能用来战斗！&r——《魔法应用学》"
		""
		"请阅读模组教程书，本章节只有部分流程和物品，无所有详细内容。"
		""
		"注意，当你手持教程书（即破旧的笔记本）时，鼠标移动到jei的物品上，即可按ctrl跳转到物品对应章节"
		"或者看到世界中的方块，也能快速浏览到对应章节"
	]
	quest.2D28C31C8C910AFF.quest_desc: ["怪物会随着你的探索越来越强大，它们会逐渐拥有词条，这些词条能够让它们拥有可怕的力量。请阅读指南，了解详细信息。"]
	quest.2D4D35D07109F822.quest_desc: ["你已经厌倦了天天喝鲜血或是啃人类心脏的日子，你渴望更特别更美味的东西。尽管你能享用人类的美食，但这些食物并不能消除你对于鲜血的渴望，也不能提供给你鲜血的力量。于是天才的你研究出了一些&c吸血鬼佳肴&r！"]
	quest.2D4D35D07109F822.title: "血族也有美食"
	quest.2D624D727FCC0CC8.quest_desc: ["可以制作强力彩虹套装"]
	quest.2D8AE636CF896FAD.quest_desc: [
		"24*24*25"
		"有一层棕色陶瓦作为地基"
		""
		"原版建筑3层小别墅"
		"无内饰，但有基本的楼梯、照明、窗户等等"
		"&a很适合前期安家！&r"
		"{image:ftbquests:textures/picture/building13.png width:177 height:100 align:center}"
	]
	quest.2D8AE636CF896FAD.quest_subtitle: "作者蓝图站-."
	quest.2D96207560AB8F85.title: "冰棘"
	quest.2DD4B8234FF36D84.quest_desc: ["关于下界新添加的&e生物群系&r"]
	quest.2E14CC9F6021D89D.quest_desc: [
		"与光辉的力量同调的戒指，能够在日间与彩虹套装产生共鸣提升自身属性。"
		""
		"身上每装备一件彩虹套装中的护甲，就能够在日间获得1层“虹之共鸣”效果，每层“虹之共鸣”效果能为玩家提供："
		""
		"0.25触及距离"
		""
		"0.25攻击范围"
		""
		"5生命上限"
		""
		"1护甲韧性"
		""
		"5%移动速度"
		""
		"（暗影钢之戒效果一样，不过是在晚上生效）"
	]
	quest.2E28B06E459E0818.quest_desc: ["下界合金套装"]
	quest.2E28B06E459E0818.title: "下界合金套装"
	quest.2E353BE85E854278.quest_desc: ["你看中了吸血鬼森林地上的一种蘑菇：弱小的吸血鬼会用它来充饥，高贵的血族对这种算不了血食的东西不屑一顾。但你发现它对于你来说似乎异常的美味"]
	quest.2E43AFA65793B795.quest_desc: [
		"整合包添加了&evoxy&r（比遥远的地平线更轻量的超视距模组），由于是移植版，可能不够稳定。但目前没发现什么问题。"
		"你可以在b站内搜索voxy相关教程，配合chunky（整合包已有）进行区块加载"
		"整合包自带光影里有bliss和photon标有voxy的可以支持voxy，你也可以自行前往下载你喜欢的、支持voxy的光影"
	]
	quest.2E4DB55BAD48F54D.quest_desc: ["请查看教程书对应章节"]
	quest.2E7ABC2BEE94E47A.quest_desc: ["当一个村庄加入狼人派别后，村民将转化为狼人村民。它们在满月时会变成狼"]
	quest.2EA527533DF10C5B.quest_desc: ["本章节是一些可合成的强力附魔书（不包括原版附魔）"]
	quest.2EE9DC3F46CA6069.quest_subtitle: "查阅教程书"
	quest.2F21D51626DE4864.quest_desc: ["有时你在村庄中会触发别的阵营来袭击你，给他们点颜色看看"]
	quest.2F21D51626DE4864.title: "袭击"
	quest.2F2C972B4922A184.quest_desc: ["整合了上述4种钟的功能（关于星空的想法请额外完成其它派系的任务书章节获得）"]
	quest.2F33E7ECB1F5322D.quest_desc: [
		"此物品强得离谱，我宣布它是mvp！"
		""
		"(可以染色)"
	]
	quest.2F58B649D2CA80BD.quest_desc: [
		"该任务会在玩家当前难度等级大于等于20级后自动解锁，小于18级则自动重置"
		"奖励会自动领取"
	]
	quest.2F807DC2B5A26316.quest_desc: ["羊毛/风帆框架/风帆达到128个"]
	quest.2F807DC2B5A26316.quest_subtitle: "组装最高等级的风车"
	quest.301CB3F9ACD07DC8.quest_desc: [
		"&5于机械建造中领悟世界本质"
		""
		"&5获取低劣者们的臣服"
		""
		"&5令威严遍布世界，凶名传唱万古"
		""
		"&5让沽名钓誉之辈消失于世界"
		""
		"&5恩泽遍及众生"
		""
		"&5向无上虚空举行献祭仪式......&r"
		""
		"{@pagebreak}"
		"具体描述："
		"&b扳手使用次数 > 300"
		"&b击杀吸血鬼数 > 100"
		"&b击杀猎人数 >200"
		"&b杀死吸血鬼特使 >1"
		"&b感染生物 > 150"
		"&r&d虚空仪式&r：&e在夜晚，前往y=-63层，物品栏携带物品“母亲之核”&8（'vampirism:mother_core'）&r，&e然后想办法死亡在y=-63层"
		"&r（死亡不掉落开启与否不影响，所需物品会正常消耗）"
		""
		"说明：上述数字要求是统计信息里的数据，即，从游戏开始到此时，进行过的都算入统计里"
		""
		"补充： 聊天栏直接发送信息  levelupinfo  即可查询进度（注意，是直接发送信息，不要加/符号，这不是指令）"
	]
	quest.302852995B59A6B7.quest_desc: [
		"船舵：用于建造和控制船只，离远一点shift右键打开其UI，可使船只物理化，物理化后右键即可开船和转向。如果你的船上面装有eureka的气球（组装后变成飞艇），按空格可上升，按V可下降。"
		"可以使其连接的所有方块物理化为一个整体。"
		""
		"船锚：把锚放在飞船上并应用红石时将船固定在当前位置（只能固定船舵带来的运动，对其它推进方式如螺旋桨，无效）"
		""
		"船舶引擎：用于给使用船舵行进的船提供动力，使用燃料让它配合船舵工作。"
	]
	quest.302852995B59A6B7.title: "船舵"
	quest.309F053A71D079DD.quest_desc: ["熔炼不死图腾以获取制作材料"]
	quest.309F053A71D079DD.title: "生命套装"
