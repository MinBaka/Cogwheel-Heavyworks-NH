	quest.12DDA6301E7527FF.title: "金粒矿脉"
	quest.12F6A8BB8B3BC6AB.quest_desc: ["快速到达基岩层，制作原油钻井时会比较有用"]
	quest.12F86EA815970400.quest_desc: ["你可以重复上述步骤，一直升到14级，接下来就是成为狼人领主了！"]
	quest.13188111C60913E5.quest_desc: ["请参考教程书：收容罐条目"]
	quest.131EF05811E16C02.quest_desc: ["&6你铸就火元素之核心，自此，火魔法的磅礴之力尽为你驱策。"]
	quest.131EF05811E16C02.title: "&6火之核心"
	quest.13370694861E2A6A.quest_desc: [
		"&e只能自然生成&r在主世界的折跃枢纽塔中，允许玩家进行跨维度传送，无法合成。"
		""
		"自然生成的折跃塔在首次右击时给予玩家一张绑定到当前折跃枢纽塔的枢纽折跃卷轴。"
		""
		"所有折跃枢纽共享一个9个格子的物品栏，可空手潜行+右击打开放入枢纽折跃卷轴&b（如果你把它抱起来了，可以远离一点再空手潜行右键）&r，右击开启传送目标选择GUI。"
		""
		"自然生成的折跃枢纽在传送时不消耗魔源，玩家放置的折跃枢纽每次传送消耗1000点魔源。"
		""
		"你可以使用探险家指南针搜索&enexus tower&r进行寻找"
	]
	quest.13370694861E2A6A.title: "折跃枢纽"
