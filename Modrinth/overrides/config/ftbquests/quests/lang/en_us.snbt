	quest.0E5CE3C432140070.title: "粗锌矿脉"
	quest.0EA235CB840C1699.title: "连锁采集"
	quest.0EEF09CC2BF9714C.quest_desc: [
		"使用恶意精华和恶意净化药水右键生物  可以增减生物的等级"
		"（恶意精华增加100级，净化药水清零）"
		"你可以把词条赋予给女仆（注意词条的描述，例如杀戮光环会以玩家为目标，所以不要给女仆赋予这种词条！而例如重装等词条则完全可以）"
	]
	quest.0EF953494E60622E.quest_desc: ["50概率出创造烈焰蛋糕"]
	quest.0EF953494E60622E.title: "&c创造烈焰蛋糕"
	quest.0F05A78ABD713A30.quest_desc: [
		"击杀强大的阿尔法狼人，能够获得狼牙。狼牙可用于后期成为狼人领主任务"
		"阿尔法狼人对标吸血鬼伯爵，拥有5个等级，但每种等级都会掉落狼牙"
	]
	quest.0F4E7AC5420C6123.quest_desc: [
		"62*83*62"
		"有一层草方块地板"
		""
		"&c说明：此建筑完全无内饰！！！"
		"分层、地板、楼梯什么的都没有！！"
		"里面是完全毛坯，还有些发光菌核、石头堆积！！&r"
