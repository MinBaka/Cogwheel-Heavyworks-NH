	quest.13892099C6FE9101.quest_subtitle: "建造最高等级的锅炉"
	quest.13F956A82897B6A8.quest_desc: ["改变你所站位置区块的矿脉"]
	quest.13F956A82897B6A8.title: "粗铜矿脉"
	quest.145369143B952BDA.quest_desc: ["玩家亲自击杀监守者以获取制作材料"]
	quest.145369143B952BDA.title: "幽匿套装"
	quest.14694BAAAC4B7F69.quest_desc: ["可以使用机械动力的动力收割机，或者法术炮塔+收获魔符的法术作为替代"]
	quest.149D74E77D10BC16.quest_desc: ["大后期前往火星后才能制作，过度用，用于合成火星钢宇航服"]
	quest.149D74E77D10BC16.title: "火星钢套装"
	quest.14C5A920A735C9FC.quest_desc: ["你在世界中冒险时，会遇到这种彩色的树：至高树，它们蕴含魔力，是你发展中必不可少的一环"]
	quest.14C5A920A735C9FC.title: "至高木"
	quest.15204561920A2642.quest_desc: ["概率出创造魔源罐"]
	quest.15204561920A2642.title: "&c创造魔源罐"
	quest.1591238526DB52A9.quest_desc: ["大后期前往火星才能够获取，其衣服能充氧气以规避外星真空的伤害"]
	quest.1591238526DB52A9.title: "火星钢宇航服套装"
	quest.159471E25D83C72A.quest_desc: ["部署在动态结构上的螺旋桨轴承或物理轴承上，旋转可产生力，方向与旋转方向有关"]
	quest.1607FC7D4C45829A.quest_desc: [
		"（不明原因跳转link无法使用）"
		"请手动跳转章节“一些小玩意”查看自动化相关条目"
	]
	quest.16717B0EA0E45493.quest_desc: [
		"&5 于机造营筑中洞彻天地本根"
		""
		"&5 收揽凡庸之辈的俯首归从"
		""
		"&5 令威棱遍布八荒，雄名昭垂万代"
		""
		"&5 让欺世盗名之徒泯绝于尘寰"
		""
		"&5 惠泽遍及群生"
		""
		"&5 向无上太虚恭行祀典仪轨......&r"
		"{@pagebreak}"
		"具体描述："
		"&b扳手使用次数 > 500"
		"&b击杀吸血鬼数 > 200"
		"&b击杀猎人数 >300"
		"&b杀死吸血鬼特使 >3"
		"&b感染生物 > 200"
		"&r&d虚空仪式&r：&e在夜晚，想办法运送吸血鬼男爵x1、阿尔法狼人x1、猎人特使x1到基岩层（接近虚空之处，y-60以下），然后杀死三者（不要使用枪械，否则无法检测）"
		""
		"说明：上述数字要求是统计信息里的数据，即，从游戏开始到此时，进行过的都算入统计里"
		""
		"补充： 聊天栏直接发送信息  levelupinfo  即可查询进度"
	]
	quest.16747E94386C4714.quest_desc: ["可以&a无视维度限制&r，在任何地方访问讲台"]
	quest.168FEF5E75606FDA.quest_desc: ["击杀&e巫妖&r后可以解除暮色沼泽，黑暗森林，雪森林的不可进入结界"]
	quest.16D042274D79BEB1.quest_desc: ["to the moon"]
	quest.16D042274D79BEB1.title: "去月球！"
	quest.16DDF943379136B5.quest_desc: [
		"从<&c我是高贵的血族&r><&9我是吸血鬼猎人&r><&3我是月夜的梦魇&r>三个章节中选择一个开始游玩，从&c血族&r、&9猎人&r、&3狼人&r三个身份中选择一个（当然，你也可以先一直保持为人类，想怎么玩取决于你）。三条线为平行并列玩法，你可以随时放弃该线转而游玩另外俩。"
		""
		"如果是新手，且对于这三个产生了一点点选择困难，那么我推荐成为&c吸血鬼&r，它有着比另外两个更为丰富的玩法。当你血族线毕业后再进行其它身份的游玩并不算迟。"
		""
		"当你选择好了之后，就请前往对应章节吧，按照流程进行发展！"
	]
	quest.16DDF943379136B5.title: "&c血族传说！"
	quest.16E4C86C0723E913.quest_desc: [""]
	quest.16E4C86C0723E913.title: "稳定之体"
	quest.16EC0F42F79B6542.quest_desc: ["放置在物理结构中，当物理结构偏转时会产生红石信号"]
	quest.16F13851FC797BA0.title: "生命修补"
	quest.174AF19BCAA4482A.title: "盔甲耐久"
	quest.1829BF28DAEB46B1.quest_desc: ["你没有在这里找到外星基地。不过你发现一件惊人的事：水星地下有一个惊人的空腔！这里只有一些冰锥和某种植物或者是真菌留下的核心体，你再次感到一阵头疼，你越来越接近真相了"]
	quest.18884F570998E085.quest_desc: [
		"你可以在各种战利品箱中发现吸血鬼之书，上面记载了一些东西。"
		""
		"也可以通过击杀高阶吸血鬼（和高阶猎人）概率获得"
		""
		"重要的是，它可以用来提升你的吸血鬼等级"
		""
		"或许这种书重要的是它所蕴含的能量，而不是书所记载的内容"
		"你觉得可以使用机械仿制出蕴含同种能量的书用于升级（点击查看配方）"
	]
	quest.18884F570998E085.title: "吸血鬼之书"
	quest.18A2C33662AE3BAE.quest_subtitle: "在1w格+的岩浆海中抽取岩浆"
	quest.18B12887FC52B60C.quest_desc: ["你现在是一名血族了，奇怪的是，不同于其他吸血鬼，虽然你仍然会对大蒜感到恶心，但你却可以食用人类的食物以及获得部分食物上的buff。"]
	quest.18B12887FC52B60C.quest_subtitle: "成为一个吸血鬼"
	quest.18B12887FC52B60C.title: "成为吸血鬼"
